// 🔒 CORE SYSTEM - DO NOT MODIFY
// This is the database schema for the SaaS boilerplate.
// Users should NOT edit this file. The schema ensures subscription and entitlement logic.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model for authentication and profile data
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // "user" or "admin"

  // Auth relationships
  accounts Account[]

  // Subscription relationships
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// NextAuth.js Account model
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}


// Subscription plans (free, pro, enterprise, etc.)
model Plan {
  id          String   @id @default(cuid())
  name        String   @unique // "free", "pro", "enterprise"
  displayName String   // "Free Plan", "Pro Plan"
  description String?
  price       Int      // Price in cents (0 for free)
  interval    String   @default("month") // "month", "year"
  isActive    Boolean  @default(true)
  
  // Payment provider IDs
  stripePriceId    String?  @unique // Stripe price ID (e.g., "price_xxx")
  razorpayPlanId   String?  @unique // Razorpay plan ID (e.g., "plan_xxx")

  // Relationships
  subscriptions Subscription[]
  entitlements  PlanEntitlement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("plans")
}

// User subscriptions to plans
model Subscription {
  id                     String             @id @default(cuid())
  userId                 String
  planId                 String
  provider               PaymentProvider    @default(stripe) // "stripe" or "razorpay"
  providerSubscriptionId String?            @unique // Stripe/Razorpay subscription ID
  providerCustomerId     String?            // Stripe customer ID or Razorpay customer ID
  status                 SubscriptionStatus @default(active)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, planId, status]) // User can only have one active subscription per plan type
  @@index([providerSubscriptionId])
  @@index([providerCustomerId])
  @@map("subscriptions")
}

enum PaymentProvider {
  stripe
  razorpay
}

// Features/access rights that plans provide
model Entitlement {
  id          String @id @default(cuid())
  name        String @unique // "feature_basic", "feature_pro", "api_calls_1000"
  displayName String // "Basic Features", "Pro Features", "1000 API Calls"
  description String?

  // Relationships
  plans PlanEntitlement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("entitlements")
}

// Many-to-many relationship between Plans and Entitlements
model PlanEntitlement {
  id            String @id @default(cuid())
  planId        String
  entitlementId String

  plan        Plan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  entitlement Entitlement @relation(fields: [entitlementId], references: [id], onDelete: Cascade)

  @@unique([planId, entitlementId])
  @@map("plan_entitlements")
}

// NextAuth.js verification tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum SubscriptionStatus {
  incomplete
  incomplete_expired
  trialing
  active
  past_due
  canceled
  unpaid
  paused
}

// AI usage tracking for monitoring and cost control
model AiUsage {
  id               String   @id @default(cuid())
  userId           String
  provider         String   // "openai", "anthropic"
  model            String   // "gpt-4o-mini", "claude-3-5-sonnet", etc.
  promptTokens     Int
  completionTokens Int
  totalTokens      Int

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("ai_usage")
}
